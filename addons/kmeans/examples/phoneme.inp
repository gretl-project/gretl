set verbose off
include kmeans.gfn

open phoneme_small.gdtb -q
list L = x1 .. x255
matrix X = {L}
k = nelem(values(g))
n = nelem(L)
scalar tm

# Hartigan and Wong initializer
set stopwatch
bundle b = kmeans(X, k, _(init="hw"))
printf "gretl, hw init, elapsed: %gs\n", $stopwatch
kmeans_sil_plot(b, L)
quit

# Principal Components initializer
set stopwatch
bundle b = kmeans(X, k, _(init="pc"))
printf "gretl, pc init, elapsed: %gs\n", $stopwatch

printf "gretl: SST, global:   %7d\n", round(b.global_SST)
printf "gretl: SST, clusters: %7d\n", round(b.cluster_SST)
series phoneme_hat = b.cluster_id

kmeans_crosstab(phoneme_hat, g)

bundle f = $sysinfo.foreign
if !f.Rbin && !f.Rlib
	quit
endif

foreign language=R --send-data=L
	X <- gretldata
	ptm <- proc.time()[3]
	km <- kmeans(X, 5, nstart=2);
	elapsed <- proc.time()[3] - ptm
	cat(sprintf("R, elapsed: %gs\n", elapsed))
	cat(sprintf("R: SST, global:   %7.0f\n", km$totss))
	cat(sprintf("R: SST, clusters: %7.0f\n", km$tot.withinss))
	hat <- as.matrix(km$cluster);
	gretl.export(hat);
end foreign

series R_phhat = mread("hat.mat", 1)
kmeans_crosstab(R_phhat, phoneme_hat)
