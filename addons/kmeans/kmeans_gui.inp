function string get_metric (const int distance)
    /* Only for kmeansGUI(). Maps the integer code to the name of
       the distance measure.
    */
    strings Distances = all_metrics()
    return Distances[distance]
end function

function bundle kmeansGUI (const list X "Features",
                           const int n_clusters[1::3] "No. of clusters (k)",
                           const int n_draws[0::8] "No. of random draws",
                           bool verbose[TRUE] "Detailed output?",
                           const int metric[1:6:1] "Metric" {"euclidean", "manhattan", "hamming", "chebyshev", "cosine", "mahalanobis"})
    /* Function for creating GUI dialog box. */

    bundle self = defbundle()
    self.metric = get_metric(metric)
    self.verbosity = verbose ? 2 : 1
    self.n_draws = n_draws
    # Only for given k
    bundle Model = kmeans_fit(X, n_clusters, self)
    kmeans_summary(Model)
    print Model.centroids

    return Model
end function

function void GUI_kmeans_plot(bundle *kmb, int ptype[0:2:0] \
                              "Plot type" {"Pair plot", "Scree plot", "Silhouette plot"})

    list X = kmb.xlist
    smpl X --no-missing

    if ptype == 0
        series factor = kmb.cluster_id
        PairPlot(X, factor)
    elif ptype == 1
        nc = kmb.n_clusters
        matrix scree = kmeans_scree(X, nc+1)
        kmeans_screeplot(scree)
    elif ptype == 2
        kmeans_sil_plot(kmb, X)
    endif
end function

function matrix kmeans_plot_precheck (bundle *kmb)
    # unconditional for the moment, but you never know 
    if 0
        return {1,1,0}
    else
        return {1,1,1}
    endif
end function
