function string get_metric (const int distance)
    /* Only for kmeansGUI(). Maps the integer code to the name of
       the distance measure.
    */
    strings Distances = all_metrics()
    return Distances[distance]
end function

function void kmeans_distances_print (const bundle b)
    between_variation = b.total_variation - b.within_variation
    between_pc = 100 * between_variation / b.total_variation

    printf "\nResults:\n"
    printf "  Total variation: %g\n", b.total_variation
    printf "  Within-cluster variation: %g\n", b.within_variation
    printf "  Between-cluster variation: %g\n", between_variation
    printf "  Between as percent of total: %.3f\n", between_pc
    printf "\n"
end function

function bundle kmeansGUI (const list X "Features",
                           const int n_clusters[1::3] "No. of clusters (k)",
      const int n_draws[0::10] "No. of random draws",
      const int metric[1:6:1] "Metric" {"euclidean", "manhattan", "hamming", "chebyshev", "cosine", "mahalanobis"},
      bool verbose[TRUE] "Detailed output?")
    /* Function for creating GUI dialog box. */

    bundle self = defbundle()
    self.metric = get_metric(metric)
    self.verbosity = verbose ? 2 : 1
    self.n_draws = n_draws
    # self.init = "pc" ?

    bundle Model = kmeans_fit(X, n_clusters, self)
    if !metric_is_euclidean(self.metric)
        # kmeans_summary(Model)
        kmeans_distances_print(Model)
    endif

    return Model
end function

function void GUI_kmeans_plot(bundle *kmb, int ptype[1:3:1] \
                              "Plot type" {"Pair plot", "Scree plot", "Silhouette plot"})

    list X = kmb.xlist
    smpl X --no-missing

    if ptype == 1
        include PairPlot.gfn
        series factor = kmb.cluster_id
        PairPlot(X, factor)
    elif ptype == 2
        nc = kmb.n_clusters
        matrix scree = kmeans_scree(X, nc+1)
        kmeans_screeplot(scree)
    elif ptype == 3
        kmeans_sil_plot(kmb, X)
    endif
end function

function matrix kmeans_plot_precheck (bundle *kmb)
    if rows(kmb.centroids) > 16 || cols(kmb.centroids) > 9 
        # ensure we're calling PairPlot with sensible dimensions
        return {0,1,1}
    else
        return {1,1,1}
    endif
end function
