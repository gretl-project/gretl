function bundle handle_options_and_defaults (bool plotting,
                                             bundle opts[null])
    # Compose self bundle, merging information from @opts

    if !exists(opts)
        bundle opts = defbundle()
    else
        if inbundle(opts, "metric")
            verify_metric(opts.metric)
        elif inbundle(opts, "distance_type")
            # backward compatibility
            opts.metric = opts.distance_type
            verify_metric(opts.metric)
            delete opts.distance_type
        endif
        if inbundle(opts, "init")
            if opts.init == "pca"
                opts.init = "pc"
            endif
        elif inbundle(opts, "initializer")
            # backward compatibility
            opts.init = opts.initializer
            if opts.init == "pca"
                opts.init = "pc"
            endif
            delete opts.initializer
        endif
    endif

    bundle self = default_values(plotting)
    self = opts + self # override defaults

    return self
end function

function strings all_metrics (void)
    return defarray("euclidean", "manhattan",
      "hamming", "chebyshev", "cosine", "mahalanobis")
end function

function void verify_metric (const string s)
    strings dtypes = all_metrics()
    scalar matches = 0
    scalar n = strlen(s)
    loop i=1..nelem(dtypes)
        if strncmp(s, dtypes[i], n) == 0
            matches++
        endif
    endloop
    errorif(matches == 0 || matches > 1,
      sprintf("Invalid metric '%s'", s))
end function

function string full_metric_name (const string s)
    strings mtypes = all_metrics()
    scalar n = strlen(s)
    string ret = ""
    loop i=1..nelem(mtypes)
        if strncmp(s, mtypes[i], n) == 0
            ret = mtypes[i]
            break
        endif
    endloop
    return ret
end function

function scalar metric_is_euclidean (const string s)
    return strncmp(s, "euclidean", strlen(s)) == 0
end function

function bundle default_values (bool plotting)
    /* Set default values. */

    bundle self = defbundle()
    scalar self.error = FALSE
    scalar self.verbosity = plotting ? 0 : 1
    string self.init = "random"
    scalar self.n_draws = 10
    scalar self.max_iter = 128
    scalar self.tolerance = 1e-4
    string self.metric = "euclidean"
    scalar self.nobs = $nobs

    if plotting
        scalar self.use_circles = FALSE
        scalar self.linewidth = 1.5
        scalar self.fontsize = 10
    endif

    return self
end function

function matrix initialize_centroids (const matrix features,
                                      const bundle self)
    scalar k = self.n_clusters
    string init = tolower(self.init)
    # "pc" is not supported for k = 1
    init = k == 1 ? "random" : init
    matrix centroids

    if init == "random"
        centroids = features[randperm(rows(features), k),]
    elif init == "pc"
        centroids = init_centroids_by_pc(features, k)
    elif init == "user"
        centroids = self.centroids0
    else
        funcerr "Invalid 'init' value"
    endif
    return centroids
end function

function matrix init_centroids_by_pc (const matrix features,
                                      int k)
    /* Pick data points that are as far apart as possible by
       means of Principal Components
    */
    errorif(k < 2, "At least two clusters are required.")

    scalar n_obs = rows(features)
    scalar step = floor((n_obs - 1) / (k - 1))
    matrix mask = 1 + seq(0, (k - 1)) * step
    matrix pc = princomp(features, 1, 1) ~ seq(1, n_obs)'
    pc = msortby(pc, 1)
    mask = pc[mask, 2]

    return features[mask,]
end function

function series kmeans_predict (const list xlist "Features",
                                const bundle Model)
    /* Predict cluster membership for a given model,
       returning the result as a series.
    */
    errorif(sum(missing(xlist)),
      "Some features have missing values. Please drop these first.")
    matrix distances = distance({xlist}, Model.metric, Model.centroids)
    series cluster_id = iminr(distances)

    return cluster_id
end function

function void call_ASA136 (const matrix X, bundle *self)
    bundle opts = _()
    if inbundle(self, "verbosity")
        opts.verbosity = self.verbosity # FIXME
    endif
    if inbundle(self, "n_draws")
        opts.rand_starts = self.n_draws
    endif
    if inbundle(self, "init")
        if self.init == "pc"
            opts.init = "pc"
        endif
    endif
    if inbundle(self, "clusters0")
        bundle b = kmeans(X, self.clusters0, opts)
    else
        bundle b = kmeans(X, self.n_clusters, opts)
    endif
    m = rows(X)
    n = cols(X)
    self.within_distance = b.cluster_SST
    self.total_distance = b.global_SST
    self.cluster_id = b.clustid
    self.centroids = b.clustinfo[,2:end-1]
    matrix dsq = zeros(m, 1)
    loop i=1..m
        k = b.clustid[i]
        loop j=1..n
            d = X[i,j] - self.centroids[k,j]
            dsq[i] += d * d
        endloop
    endloop
    self.distances = dsq
    scalar self.between_distance = self.total_distance - self.within_distance
    scalar self.between_fraction = self.between_distance / self.total_distance
    # other components?
end function

function void print_draw_info (int d, int dmax, const bundle b)
    if dmax > 9
        printf "draw %02d: ", d
    else
        printf "draw %d: ", d
    endif
    if b.error
        printf "failed\n"
    else
        printf "total within distance = %g\n", d, b.within_distance
    endif
end function

function bundle kmeans_fit (const list xlist,
                            numeric clusters,
                            bundle opts[null])
    /* Estimate clusters. */

    if typeof(clusters) == 3
        # we got an initial clusters matrix
        errorif(cols(clusters) != nelem(xlist),
          sprintf("Columns of clusters (%d) doesn't match number of features (%d)",
          cols(clusters), nelem(xlist)))
        matrix clusters0 = clusters
        n_clusters = rows(clusters)
    elif typeof(clusters) == 1
        # got a scalar
        if clusters != floor(clusters)
            funcerr "kmeans_fit: clusters must be an integer or a matrix"
        else
            n_clusters = clusters
        endif
    else
        funcerr "kmeans_fit: clusters must be an integer or a matrix"
    endif

    if !exists(opts)
        bundle opts = defbundle()
    endif

    errorif(sum(missing(xlist)),\
      "Some features have missing values. Please drop these first.")

    bundle self = handle_options_and_defaults(0, opts)
    self.init = tolower(self.init)

    scalar self.n_clusters = n_clusters
    if exists(clusters0)
        matrix self.clusters0 = clusters0
        self.init = "user"
    endif
    matrix features = {xlist}
    scalar self.within_distance = $huge
    scalar draw_id = 1
    matrix self.cluster_id = mshape(NA, $nobs, 1)
    matrix self.distances = mshape(NA, $nobs, 1)
    scalar n_errors = 0

    if n_clusters == 1
        # special handling for the trivial case
        self.n_draws = 0
        matrix self.cluster_id = ones($nobs, 1)
        matrix self.centroids = meanc(features)
        matrix D = distance(features, self.metric, self.centroids)
        matrix self.distances = sumr(D)
        scalar self.total_distance = sumc(self.distances)
        scalar self.within_distance = self.total_distance
    endif

    if self.verbosity
        printf "kmeans_fit: %d observations, %d features, %d clusters\n",
          $nobs, nelem(xlist), n_clusters
        printf "metric %s, initializer %s, %d random draws\n",
          full_metric_name(self.metric), self.init, self.n_draws
    endif

    if n_clusters == 1
        if self.verbosity
            printf "Sum of within distances = %g\n", self.within_distance
        endif
        return self
    endif

    if metric_is_euclidean(self.metric)
        call_ASA136(features, &self)
        return self
    endif

    string save_init = self.init

    if save_init == "pc" || save_init == "user"
        bundle b = compute_kmeans(self, features)
        scalar self.within_distance = b.within_distance
        matrix self.centroids = b.centroids
        matrix cluster_id = b.cluster_id
        matrix distances = b.distances
        if self.verbosity == 2
            printf "%s init: total within distance = %g\n",
              save_init == "pc" ? "PC" : "user", b.within_distance
        endif
        # hand off to random for n_draws > 0
        self.init = "random"
    endif

    loop d=1..self.n_draws
        bundle b = compute_kmeans(self, features)
        if self.verbosity == 2
            print_draw_info(d, self.n_draws, b)
        endif
        if b.error
            n_errors++
            continue
        endif
        # record minimizing draw
        if b.within_distance < self.within_distance
            scalar self.within_distance = b.within_distance
            matrix self.centroids = b.centroids
            matrix cluster_id = b.cluster_id
            matrix distances = b.distances
        endif
    endloop

    self.init = save_init

    if self.n_draws > 0 && n_errors == self.n_draws
        string msg = "All random initializations failed. Please check your data."
        funcerr "@msg"
    endif

    cnameset(self.centroids, varnames(xlist))
    if self.verbosity
        printf "minimized objective function: %g\n\n", self.within_distance
        print self.centroids
    endif

    matrix self.cluster_id = cluster_id
    matrix self.distances = distances
    add_variations(features, &self)

    return self
end function

function void add_variations (const matrix features, bundle *self)
    /* Add variation statistics */

    matrix distances_from_mean = distance(features, self.metric, meanc(features))
    if metric_is_euclidean(self.metric)
        self.total_distance = sumc(distances_from_mean.^2)
    else
        self.total_distance = sumc(distances_from_mean)
    endif
    scalar self.within_distance = within_cluster_distance(self.distances,
      self.cluster_id, self.metric)
    scalar self.between_distance = self.total_distance - self.within_distance
    scalar self.between_fraction = self.between_distance / self.total_distance
end function

function void kmeans_summary (const bundle b)
    /* Print summary after fitting. */

    print "************************************************"
    print "*** K-means clustering ***"

    printf "\nParameters\n"
    printf "  Number of clusters: %d\n", b.n_clusters
    printf "  Metric: %s\n", full_metric_name(b.metric)
    printf "  Initializer: %s\n", b.init
    printf "  Number of random draws: %d\n", b.n_draws
    printf "  Tolerance: %f\n", b.tolerance

    printf "\nResults:\n"
    if metric_is_euclidean(b.metric)
        printf "  Total sum of squares: %g\n", b.total_distance
        printf "  Within-cluster sum of squares: %g\n", b.within_distance
        printf "  Between-cluster sum of squares: %g\n", b.between_distance
        printf "  (Between / Total): %.3f pct.\n", (b.between_fraction * 100)
    else
        printf "  Total distance from global centroid: %g\n", b.total_distance
        printf "  Total within-cluster distance: %g\n", b.within_distance
        printf "  Between cluster distance: %g\n", b.between_distance
        printf "  (Between / Total): %.3f pct.\n", (b.between_fraction * 100)
    endif
    print "************************************************"
end function

function bundle compute_kmeans (const bundle self,
                                const matrix features)
    /* Actual computation of k-means. Identify optimal clusters and
       return a bundle.
    */
    bundle Model
    matrix centroids = initialize_centroids(features, self)
    scalar k = self.n_clusters
    scalar prev_distance = $huge
    scalar this_distance
    scalar Model.error = FALSE

    loop iter = 1..self.max_iter
        matrix all_dists = distance(features, self.metric, centroids)
        matrix cluster_id = iminr(all_dists)

        if rows(values(cluster_id)) == k  # check + update
            matrix centroids = compute_centroids(features, cluster_id)
            matrix min_dists = minr(all_dists) # select minimum from all
        else
            Model.error = TRUE
            break
        endif

        this_distance = within_cluster_distance(min_dists, cluster_id,
          self.metric)
        delta = this_distance - prev_distance
        if delta <= 0 && abs(delta) < self.tolerance
            if self.verbosity > 2
                printf "Converged after %d iterations (within total distance = %.5f).",
                  iter, this_distance
                flush
            endif
            break
        endif
        prev_distance = this_distance
    endloop

    matrix Model.distances = min_dists
    scalar Model.within_distance = this_distance
    matrix Model.cluster_id = cluster_id
    matrix Model.centroids = centroids

    return Model
end function

function scalar within_cluster_distance (const matrix distances,
                                         const matrix cluster_id,
                                         const string metric)
    /* Compute the sum of the distances between observations and
       cluster centroids across all clusters.
    */

    if metric_is_euclidean(metric)
        # in k-means, the convention seems to be to work with the sum
        # of squares itself rather than the square root of same
        matrix agg = aggregate(distances.^2, cluster_id, sum)
    else
        # other metrics should not be squared
        matrix agg = aggregate(distances, cluster_id, sum)
    endif
    return sumc(agg[,3])
end function

function matrix compute_centroids (const matrix features,
                                   const matrix cluster_id)
    /* Computes the centroid for each cluster.
       Returns a matrix with n_clusters rows and cols(features) columns.
       Row i pertains to cluster i; column j holds the mean of feature j
       for the cluster.
    */

    matrix tmp = aggregate(features, cluster_id, mean)
    strings row_labels = "Centroid=" ~ tmp[,1]
    centroids = tmp[,3:]
    rnameset(centroids, row_labels)
    return centroids
end function

function string get_metric (const int distance)
    /* Only for kmeansGUI(). Maps the integer code to the name of
       the distance measure.
    */
    strings Distances = all_metrics()
    return Distances[distance]
end function

function bundle kmeansGUI (const list X "Features",
                           const int n_clusters[1::3] "No. of clusters (k)",
      const int metric[1:6:1] "Metric" {"euclidean", "manhattan", "hamming", "chebyshev", "cosine", "mahalanobis"},
      const int plot_type[0:3:0] "Plot type" {"none", "Scree (1 to k)", "Cluster (pairs)", "Silhouette"})
    /* Function for creating GUI dialog box. */

    bundle self = defbundle()
    self.metric = get_metric(metric)
    self.verbosity = 2  # in GUI mode, highest verbosity level is activated

    if plot_type == 1
        # scree plot
        self.verbosity = 0 # ?
        matrix scree = kmeans_scree(X, n_clusters, self)
        kmeans_screeplot(scree, null, null)
        bundle Model = _(scree)
        return Model
    endif

    # Only for given k
    bundle Model = kmeans_fit(X, n_clusters, self)
    kmeans_summary(Model)
    print Model.centroids

    if plot_type == 2
        kmeans_plot(X, Model)
    endif
    if plot_type == 3
        kmeans_sil_plot(Model, X, self)
        scalar sil_score = kmeans_sil_score(Model, X, TRUE)
        matrix sil_score_local = kmeans_sil_score(Model, X, FALSE)
        printf "\nSilhouette Analysis\n"
        printf "Mean Silhouette Coefficient: %.3f\n\n", sil_score
        printf "Per Cluster Silhouette Coefficients:\n%12.3f\n", sil_score_local
    endif

    return Model
end function

function matrix kmeans_scree (const list xlist "Features",
                              const int kmax[2::3] "No. of clusters",
                              bundle opts[null])
    if !exists(opts)
        bundle opts = _()
    endif
    bundle opts = handle_options_and_defaults(0, opts)

    matrix results
    if metric_is_euclidean(opts.metric)
        opts.scree = 1
        bundle b = kmeans({xlist}, kmax, opts)
        results = b.Scree
    else
        results = zeros(kmax, 2)
        loop k=1..kmax
            bundle model = kmeans_fit(xlist, k, opts)
            errorif(model.error,
              sprintf("scree: kmeans_fit failed for k = %d\n", k))
            if opts.verbosity == 2
                kmeans_summary(model)
            endif
            results[k,] = {k, model.within_distance}
        endloop
        cnamset(results, "clusters distance")
    endif

    return results
end function

