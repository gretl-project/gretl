function bundle handle_options_and_defaults (const list xlist,
                                             bool plotting,
                                             bundle opts[null])
    # Compose self bundle, merging information from @opts

    if !exists(opts)
        bundle opts = defbundle()
    else
        if inbundle(opts, "metric")
            verify_metric(opts.metric)
        elif inbundle(opts, "distance_type")
            # backward compatibility
            opts.metric = opts.distance_type
            verify_metric(opts.metric)
            delete opts.distance_type
        endif
        if inbundle(opts, "init")
            if (opts.init == "pca")
                opts.init = "pc"
            endif
        elif inbundle(opts, "initializer")
            # backward compatibility
            opts.init = opts.initializer
            if (opts.init == "pca")
                opts.init = "pc"
            endif
            delete opts.initializer
        endif
    endif

    bundle self = default_values(xlist, plotting)
    self = opts + self          # override defaults

    return self
end function

function strings all_metrics (void)
    return defarray("euclidean", "manhattan",
      "hamming", "chebyshev", "cosine", "mahalanobis")
end function

function void verify_metric (const string s)
    strings dtypes = all_metrics()
    scalar matches = 0
    scalar n = strlen(s)
    loop i=1..nelem(dtypes)
        if strncmp(s, dtypes[i], n) == 0
            matches++
        endif
    endloop
    errorif(matches == 0 || matches > 1,
      sprintf("Invalid metric '%s'", s))
end function

function string full_metric_name (const string s)
    strings mtypes = all_metrics()
    scalar n = strlen(s)
    string ret = ""
    loop i=1..nelem(mtypes)
        if strncmp(s, mtypes[i], n) == 0
            ret = mtypes[i]
            break
        endif
    endloop
    return ret
end function

function scalar metric_is_euclidean (const string s)
    return strncmp(s, "euclidean", strlen(s)) == 0
end function

function bundle default_values (const list xlist, bool plotting)
    /* Set default values. */

    bundle self = defbundle()
    scalar self.error = FALSE
    scalar self.verbose = plotting ? 0 : 1
    string self.init = "random"
    scalar self.n_draws = 10
    scalar self.max_iter = 128
    scalar self.tolerance = 1e-4
    string self.metric = "euclidean"
    scalar self.nobs = $nobs

    if plotting
        # For kmeans_plot() and kmeans_screeplot()
        scalar self.use_circles = FALSE
        scalar self.linewidth = 1.5
        scalar self.fontsize = 10
    endif

    return self
end function

function matrix initialize_centroids (const matrix features,
                                      const bundle self)
    scalar k = self.n_clusters
    string init = tolower(self.init)
    # "pc" is not supported for k = 1
    init = k == 1 ? "random" : init
    matrix centroids

    if init == "random"
        centroids = features[randperm(rows(features), k),]
    elif init == "pc"
        centroids = init_centroids_by_pc(features, k)
    elif init == "user"
        centroids = self.centroids0
    else
        funcerr "Invalid 'init' value"
    endif
    return centroids
end function

function matrix init_centroids_by_pc (const matrix features,
                                      int k)
    /* Pick data points that are as far apart as possible by
       means of Principal Components
    */
    errorif(k < 2, "At least two clusters are required.")

    scalar n_obs = rows(features)
    scalar step = floor((n_obs - 1) / (k - 1))
    matrix mask = 1 + seq(0, (k - 1)) * step
    matrix pc = princomp(features, 1, 1) ~ seq(1, n_obs)'
    pc = msortby(pc, 1)
    mask = pc[mask, 2]

    return features[mask,]
end function

function series kmeans_predict (const list xlist "Features",
                                const bundle self)
    /* Predict cluster membership for a given model,
       returning the result as a series.
    */

    errorif(sum(missing(xlist)),
      "Some features have missing values. Please drop these first.")
    matrix distances = distance({xlist}, self.metric, self.centroids)
    series cluster_id = iminr(distances)

    return cluster_id
end function

function void call_ASA136 (const matrix X, bundle *self)
    bundle opts = _()
    if inbundle(self, "verbose")
        opts.verbosity = self.verbose # FIXME
    endif
    if inbundle(self, "n_draws")
        opts.rand_starts = self.n_draws
    endif
    if inbundle(self, "init")
        if self.init == "pc"
            opts.init = "pc"
        endif
    endif
    if inbundle(self, "clusters0")
        bundle b = kmeans(X, self.clusters0, opts)
    else
        bundle b = kmeans(X, self.n_clusters, opts)
    endif
    m = rows(X)
    n = cols(X)
    self.within_distance = b.cluster_SST
    self.total_distance = b.global_SST
    self.cluster_id = b.clustid
    self.centroids = b.clustinfo[,2:end-1]
    matrix dsq = zeros(m, 1)
    loop i=1..m
        k = b.clustid[i]
        loop j=1..n
            d = X[i,j] - self.centroids[k,j]
            dsq[i] += d * d
        endloop
    endloop
    self.distances = dsq
    scalar self.between_distance = self.total_distance - self.within_distance
    scalar self.between_fraction = self.between_distance / self.total_distance
    # other components?
end function

function bundle kmeans_fit (const list xlist,
                            numeric clusters,
                            bundle opts[null])
    /* Estimate clusters. */

    if typeof(clusters) == 3
        # we got an initial clusters matrix
        errorif(cols(clusters) != nelem(xlist),
          sprintf("Columns of clusters (%d) doesn't match number of features (%d)",
          cols(clusters), nelem(xlist)))
        matrix clusters0 = clusters
        n_clusters = rows(clusters)
    elif typeof(clusters) == 1
        # got a scalar
        if clusters != floor(clusters)
            funcerr "kmeans_fit: clusters must be an integer or a matrix"
        else
            n_clusters = clusters
        endif
    else
        funcerr "kmeans_fit: clusters must be an integer or a matrix"
    endif

    if !exists(opts)
        bundle opts = defbundle()
    endif

    errorif(sum(missing(xlist)),\
      "Some features have missing values. Please drop these first.")

    bundle self = handle_options_and_defaults(xlist, 0, opts)
    self.init = tolower(self.init)

    scalar self.n_clusters = n_clusters
    if exists(clusters0)
        matrix self.clusters0 = clusters0
        self.init = "user"
    endif
    matrix features = {xlist}
    scalar self.within_distance = $huge
    scalar draw_id = 1
    matrix self.cluster_id = mshape(NA, $nobs, 1)
    matrix self.distances = mshape(NA, $nobs, 1)
    scalar n_errors = 0

    if n_clusters == 1
        # special handling for the trivial case
        self.n_draws = 0
        matrix self.cluster_id = ones($nobs, 1)
        matrix self.centroids = meanc(features)
        matrix D = distance(features, self.metric, self.centroids)
        matrix self.distances = sumr(D)
        scalar self.total_distance = sumc(self.distances)
        scalar self.within_distance = self.total_distance
    endif

    if self.verbose
        printf "kmeans_fit: %d observations, %d features, %d clusters\n",
          $nobs, nelem(xlist), n_clusters
        printf "metric %s, initializer %s, %d random draws\n",
          full_metric_name(self.metric), self.init, self.n_draws
    endif

    if n_clusters == 1
        if self.verbose
            printf "Sum of within distances = %g\n", self.within_distance
        endif
        return self
    endif

    if metric_is_euclidean(self.metric)
        call_ASA136(features, &self)
        return self
    endif

    string save_init = self.init

    if save_init == "pc" || save_init == "user"
        bundle b = compute_kmeans(self, features)
        scalar self.within_distance = b.within_distance
        matrix self.centroids = b.centroids
        matrix cluster_id = b.cluster_id
        matrix distances = b.distances
        if self.verbose == 2
            printf "PC init: total within distance = %g\n",
              b.within_distance
        endif
        # hand off to random for n_draws > 0
        self.init = "random"
    endif

    loop d=1..self.n_draws
        bundle b = compute_kmeans(self, features)
        if b.error
            n_errors++
            if self.verbose == 2
                printf "random draw %d: failed \n", d
            endif
            continue
        endif

        if self.verbose == 2
            printf "random draw %d: total within distance = %g\n", d,
              b.within_distance
        endif

        # select minimizing draw
        if b.within_distance < self.within_distance
            scalar self.within_distance = b.within_distance
            matrix self.centroids = b.centroids
            matrix cluster_id = b.cluster_id
            matrix distances = b.distances
        endif
    endloop

    self.init = save_init

    if self.n_draws > 0 && n_errors == self.n_draws
        string msg = "All random initializations failed. Please check your data."
        funcerr "@msg"
    endif

    cnameset(self.centroids, varnames(xlist))
    if self.verbose
        printf "minimized objective function: %g\n\n", self.within_distance
        print self.centroids
    endif

    matrix self.cluster_id = cluster_id
    matrix self.distances = distances
    add_variations(features, &self)

    return self
end function

function void add_variations (const matrix features, bundle *self)
    /* Add various variation statistics.
       return: void */

    matrix distances_from_mean = distance(features, self.metric, meanc(features))
    if metric_is_euclidean(self.metric)
        self.total_distance = sumc(distances_from_mean.^2)
    else
        self.total_distance = sumc(distances_from_mean)
    endif
    scalar self.within_distance = within_cluster_distance(self.distances,
      self.cluster_id, self.metric)
    scalar self.between_distance = self.total_distance - self.within_distance
    scalar self.between_fraction = self.between_distance / self.total_distance
end function

function void kmeans_summary (const bundle self)
    /* Print summary after fitting. */

    print "************************************************"
    print "*** K-means clustering ***"

    printf "\nParameters\n"
    printf "  Number of clusters: %d\n", self.n_clusters
    printf "  Metric: %s\n", full_metric_name(self.metric)
    printf "  Initializer: %s\n", self.init
    printf "  Number of random draws: %d\n", self.n_draws
    printf "  Tolerance: %f\n", self.tolerance

    printf "\nResults:\n"
    if metric_is_euclidean(self.metric)
        printf "  Total sum of squares: %g\n", self.total_distance
        printf "  Within-cluster sum of squares: %g\n", self.within_distance
        printf "  Between-cluster sum of squares: %g\n", self.between_distance
        printf "  (Between / Total): %.3f pct.\n", (self.between_fraction * 100)
    else
        printf "  Total distance from global centroid: %g\n", self.total_distance
        printf "  Total within-cluster distance: %g\n", self.within_distance
        printf "  Between cluster distance: %g\n", self.between_distance
        printf "  (Between / Total): %.3f pct.\n", (self.between_fraction * 100)
    endif
    print "************************************************"
end function

function void kmeans_plot (const list xlist, bundle self)
    /* Plot clusters in two dimensions. */

    string self.filename = inbundle(self, "filename") ? \
      self.filename : "display"
    series factor = self.cluster_id
    PairPlot(xlist, factor, self)
end function

function bundle compute_kmeans (const bundle self,
                                const matrix features)
    /* Actual computation of k-means. Identify optimal clusters and
       return a bundle.
    */
    bundle Model
    matrix centroids = initialize_centroids(features, self)
    scalar k = self.n_clusters
    scalar prev_distance = $huge
    scalar this_distance
    scalar Model.error = FALSE

    loop iter = 1..self.max_iter
        matrix all_dists = distance(features, self.metric, centroids)
        matrix cluster_id = iminr(all_dists)

        if rows(values(cluster_id)) == k  # check + update
            matrix centroids = compute_centroids(features, cluster_id)
            matrix min_dists = minr(all_dists) # select minimum from all
        else
            Model.error = TRUE
            break
        endif

        this_distance = within_cluster_distance(min_dists, cluster_id,
          self.metric)
        delta = this_distance - prev_distance
        if delta <= 0 && abs(delta) < self.tolerance
            if self.verbose > 2
                printf "Converged after %d iterations (within total distance = %.5f).",
                  iter, this_distance
                flush
            endif
            break
        endif
        prev_distance = this_distance
    endloop

    matrix Model.distances = min_dists
    scalar Model.within_distance = this_distance
    matrix Model.cluster_id = cluster_id
    matrix Model.centroids = centroids

    return Model
end function

function scalar within_cluster_distance (const matrix distances,
                                         const matrix cluster_id,
                                         const string metric)
    /* Compute the sum of the distances between observations and centroids
       across all clusters.

       "distances" already refers to some computed distance from the centroid,
       for instance $(x_{ij} - xbar_{ij})^2$ in case of the Euclidean distance.
       But it could also be some other distance measure.
    */

    if metric_is_euclidean(metric)
        # in k-means, the convention seems to be to work with the sum
        # of squares itself rather than the square root of same
        matrix agg = aggregate(distances.^2, cluster_id, sum)
    else
        # other metrics should not be squared
        matrix agg = aggregate(distances, cluster_id, sum)
    endif
    return sumc(agg[,3])
end function

function matrix compute_centroids (const matrix features,
                                   const matrix cluster_id)
    /* Computes the centroid for each cluster.
       Returns a matrix with n_clusters rows and cols(features) columns.
       Row i pertains to cluster i; column j holds the mean of feature j
       for the cluster.
    */

    matrix tmp = aggregate(features, cluster_id, mean)
    strings row_labels = "Centroid=" ~ tmp[,1]
    centroids = tmp[,3:]
    rnameset(centroids, row_labels)

    return centroids
end function

function string get_metric (const int distance)
    /* Only for kmeansGUI(). Maps the integer code to the name of
       the distance measure. */
    strings Distances = all_metrics()
    return Distances[distance]
end function

function bundle kmeansGUI (const list X "Input",
                           const int n_clusters[1::3] "No. of clusters (k)",
      const int distance[1:6:1] "Distance type" {"euclidean", "manhattan", "hamming", "chebyshev", "cosine", "mahalanobis"},
      const int plot_type[0:3:0] "Plot type" {"none", "Scree (1 to k)", "Cluster (pairs)", "Silhouette Plot"})
    /* Function for creating GUI dialog box. */

    bundle self = defbundle()
    self.metric = get_metric(distance)
    self.verbose = 2  # in GUI mode, highest verbosity level is activated

    if plot_type == 1
        self.verbose = 0
        matrix results = kmeans_screeplot(X, n_clusters, null, self)
        bundle Model = _(results)
        return Model
    endif

    # Only for given k
    bundle Model = kmeans_fit(X, n_clusters, self)
    kmeans_summary(Model)
    print Model.centroids

    if plot_type == 2
        kmeans_plot(X, Model)
    endif
    if plot_type == 3
        kmeans_sil_plot(Model, X, self)
        scalar sil_score = kmeans_sil_score(Model, X, TRUE)
        matrix sil_score_local = kmeans_sil_score(Model, X, FALSE)
        printf "\nSilhouette Analysis\n"
        printf "Mean Silhouette Coefficient: %.3f\n\n", sil_score
        printf "Per Cluster Silhouette Coefficients:\n%12.3f\n", sil_score_local
    endif

    return Model
end function

function matrix	kmeans_screeplot (const list xlist "Features",
                                  const int kmax[1::3] "No. of clusters",
                                  const string filename[null],
                                  bundle opts[null] "Parameter bundle")
    /* Create a scree plot. */

    if !exists(opts)
        bundle opts = _()
    endif
    bundle opts = handle_options_and_defaults(xlist, 1, opts)

    string fontopt = ""
    if inbundle(opts, "fontsize")
        fontopt = sprintf("font=\",%d\"", opts.fontsize)
    endif

    string fname = exists(filename) ? filename : "display"
    matrix k_values = seq(1, kmax)'
    matrix results = k_values ~ zeros(kmax, 1)
    cnameset(results, defarray("# clusters", "distance"))

    loop i=1..nelem(k_values)
        bundle model = kmeans_fit(xlist, k_values[i], opts)
        errorif(model.error, sprintf("scree: kmeans_fit failed for k = %d\n", k_values[i]))
        if opts.verbose == 2
            kmeans_summary(model)
        endif
        results[i,2] = model.within_distance
    endloop

    print results

    matrix mplot = mreverse(results, TRUE)
    plot mplot
        options with-lp fit=none @fontopt
        literal set ylabel "Within distance"
        literal set xlabel "clusters"
        printf "set linetype 1 lw %d", opts.linewidth
        literal set grid
        literal set xtics 1
    end plot --output="@fname"

    return results
end function

function series kmeans_sil_samples (const bundle Model, const list xlist)
    /* Compute the silhouette samples for each observation. */

    matrix features = {xlist}
    matrix cluster_id = Model.cluster_id
    series silhouette_samples = zeros(Model.nobs, 1)

    loop i=1..Model.nobs
        scalar own_cluster = cluster_id[i]
        matrix own_cluster_mask = (cluster_id .= own_cluster)

        # a(i): mean distance to own cluster (excluding self)
        # can be interpreted as a measure of how well i is assigned to its
        # cluster (the smaller the value, the better the assignment).
        matrix own_points = selifr(features, own_cluster_mask)
        if sum(own_cluster_mask) > 1
            # 1st entry is the distance to self, so we skip it
            matrix dists_own = distance(features[i,], Model.metric, own_points)[2:]'
            # The pairwise distance is the same as the this one:
            /* matrix dat = features[i,] | own_points
               matrix dists_own2 = unvech(distance(dat, Model.metric), 0)[2:,1]
               out = dists_own' ~ dists_own2
               print out */
            scalar a_i = meanc(dists_own)  # mean distance to own cluster
        else
            scalar a_i = 0
        endif

        # b(i): minimum mean distance to other clusters
        scalar b_i = $huge
        loop k=1..Model.n_clusters
            if k == own_cluster
                continue
            endif
            matrix mask_k = (cluster_id .= k)
            if sum(mask_k) > 0
                matrix other_points = selifr(features, mask_k)
                matrix dists_other = distance(features[i,], Model.metric, other_points)
                scalar mean_other_distance = sum(dists_other) / nelem(dists_other)
                if mean_other_distance < b_i
                    # update the "neigboring cluster"
                    b_i = mean_other_distance
                endif
            endif
        endloop

        silhouette_samples[i] = compute_sil_sample(a_i, b_i)
    endloop

    return silhouette_samples
end function

function scalar compute_sil_sample (const scalar a_i, const scalar b_i)
    /* Compute the silhouette sample for a single observation.
       URL: https://en.wikipedia.org/wiki/Silhouette_(clustering) */

    if a_i == 0 && b_i == 0
        return 0  # avoid division by zero
    elif a_i == b_i
        return 0  # equal distances to own and other clusters
    elif a_i < b_i
        return 1 - (a_i / b_i)  # well assigned to own cluster
    else # a_i > b_i
        return (b_i / a_i) - 1  # poorly assigned to own cluster
    endif
end function

function numeric kmeans_sil_score (const bundle Model,
                                   const list xlist,
                                   const bool global [TRUE])
    /* Compute the mean Silhouette Coefficient of all samples. */

    series silhouette_samples = kmeans_sil_samples(Model, xlist)
    if global == TRUE
        score = mean(silhouette_samples)
        return score
    endif

    series cluster_id = Model.cluster_id
    matrix score = 0
    matrix mean_per_cluster = aggregate(silhouette_samples, cluster_id, "mean")[,{1,3}]
    cnameset(mean_per_cluster, defarray("Cluster", "mean(Score)"))

    return mean_per_cluster
end function

function void kmeans_sil_plot (const bundle Model,
                               const list xlist,
                               const bundle opts[null])
    /* Create a silhouette plot for the fitted kmeans model.
       Each cluster is plotted separately. */

    if !exists("opts")
        bundle opts = _()
    endif

    matrix silhouette_samples = {kmeans_sil_samples(Model, xlist)}
    scalar n_clusters = Model.n_clusters
    scalar mean_sil_score = meanc(silhouette_samples)
    matrix plot_data = silhouette_samples ~ Model.cluster_id
    strings plotfiles = array(n_clusters)

    # plot options
    string filename = inbundle(opts, "filename") ? opts.filename : "display"
    scalar width = inbundle(opts, "width") ? opts.width : 600
    scalar height = inbundle(opts, "height") ? opts.height : 900
    scalar columns = inbundle(opts, "columns") ? opts.columns : 1
    scalar rows = ceil(n_clusters / columns)
    scalar base_margin = inbundle(opts, "base_margin") ? opts.base_margin : 2.5
    scalar pointsize = inbundle(opts, "pointsize") ? opts.pointsize : 0.75
    scalar fontsize = inbundle(opts, "fontsize") ? opts.fontsize : 12
    string fsize_cmd = sprintf("font=\",%d\"", fontsize)

    # Calculate margins based on plot size and layout
    scalar margin_scale = min(width, height) / (rows * 300)
    scalar tmargin = base_margin * margin_scale
    scalar bmargin = base_margin * margin_scale

    # Prepare data for each cluster
    scalar ymin = min(plot_data) * (min(plot_data) < 0 ? 1.1 : 0.9)
    scalar ymax = max(plot_data) * (max(plot_data) < 0 ? 0.9 : 1.1)
    ymax = ymax > 1 ? 1.01 : ymax  # limit to [0, 1] range
    ymin = ymin < -1 ? -1.01 : ymin  # limit to [-1, 1] range

    loop k=1..n_clusters
        matrix cluster_mask = (plot_data[,2] .= k)
        matrix cluster_sil_values = selifr(plot_data, cluster_mask)[,1]
        cluster_sil_values = mreverse(msortby(cluster_sil_values, 1))
        cluster_sil_values ~= mean_sil_score
        cnameset(cluster_sil_values, defarray("score for data point", "mean score, all clusters"))
        print cluster_sil_values

        plot cluster_sil_values
            options fit=none time-series single-yaxis with-lines=2 \
              @fsize_cmd
            printf "set ylabel 'Cluster %d (n=%d)'", k, rows(cluster_sil_values)
            literal set grid
            literal set boxwidth 0.8
            printf "set yrange[%f:%f]", ymin, ymax
            printf "set tmargin %f", tmargin
            printf "set bmargin %f", bmargin
            printf "set linetype 1 ps %g pt 7", pointsize
            printf "set linetype 2 lw 1.5 dt 2"
            literal set key top right
            # literal set nokey
        end plot --outbuf=plotfiles[k]
    endloop

    gridplot plotfiles --cols=columns --width=width --height=height \
      --title="Silhouette plots per cluster" --output="@filename"
end function
