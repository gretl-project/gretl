# Test for bs_escape set variable in gretl introduced with gretl 2026b
# This script demonstrates the behavior of string literals with and without backslash escape

set assert stop

function void test_bs_escape_on()
	set bs_escape on
	string input = "one\ttwo\vthree"
	printf "input = '%s'\n", input
	assert(strlen(input) == 13) # \t and \v are single chars

	# The string p is supposed to be empty, since strstr() is "looking for"
	# a literal backslash in s, and s does not contain that byte.
	string actual = strstr(input, "\\")
	assert(nelem(actual) == 0) # should be empty
end function

function void test_bs_escape_off()
	set bs_escape off
	string input = "one\ttwo\vthree"
	printf "input = '%s'\n", input
	assert(strlen(input) == 15) # backslashes are literal

	catch string tmp = strstr(input, "\\") # error, as expected
    assert($error > FALSE)
end function

test_bs_escape_on()
test_bs_escape_off()
